{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/codex-5.3",
  "theme": "system",
  "keybinds": {
    "messages_last": "<leader>G",
    "editor_open": "<leader>ctrl+e"
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "webfetch": "allow"
  },
  "mcp": {
    "godoc": {
      "enabled": false,
      "type": "local",
      "command": [
        "godoc-mcp"
      ]
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    }
  }
}
