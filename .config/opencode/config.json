{
  "$schema": "https://opencode.ai/config.json",
  "model": "vercel/anthropic/claude-opus-4.7",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "webfetch": "allow"
  },
  "mcp": {
    "godoc": {
      "enabled": false,
      "type": "local",
      "command": [
        "godoc-mcp"
      ]
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    },
    "ticktick": {
      "type": "remote",
      "url": "https://mcp.ticktick.com"
    }
  }
}
