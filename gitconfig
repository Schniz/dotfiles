  user = Gal Schlezinger
  email = galstar@spitfire.co.il
  editor = /usr/local/bin/nvim
[user]
	name = Gal Schlezinger
	email = galstar@spitfire.co.il
[alias]
	ac = add . && commit
	co = checkout
	poh = push origin head
	dc = diff --cached
	bdbd = !git branch --merged | egrep -v \"(^\\*|master|dev)\" | xargs git branch -d
[help]
	autocorrect = 10
